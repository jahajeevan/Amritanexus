# ─────────────────────────────────────────────────────────────
# Amrita Nexus — Environment Variables
# Copy this file to `.env` and fill in real values for local dev.
# On Vercel, set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Public (safe to expose in the browser bundle) ──
# Supabase project URL + publishable/anon key
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Admin login email + SHA-256 hash of the admin password (never the plaintext).
# Generate the hash:  printf '%s' 'YourPassword' | shasum -a 256
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD_HASH=your_sha256_hash_here

# ── Server-only (NEVER prefixed with VITE_, never sent to the browser) ──
# Gmail account + App Password used to send OTP emails via SMTP.
# App Password is generated at https://myaccount.google.com/apppasswords
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Random secret used to sign stateless OTP tokens. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=change_me_to_a_long_random_string

# Server-side admin check (used by /api/admin-login). Keep in sync with the
# email above; store the PLAINTEXT password here only on the server (Vercel).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here
